{
	"name": "genuim-site",
	"version": "2.0.3",
	"private": true,
	"scripts": {
		"start": "http-server site -p 3000 -c-1",
		"start:e2e": "http-server site -p 3000 -c-1 --silent",
		"build:css": "tailwindcss -i ./site/assets/css/input.css -o ./site/assets/css/output.css --minify",
		"dev": "tailwindcss -i ./site/assets/css/input.css -o ./site/assets/css/output.css --watch",
		"lint": "biome check package.json biome.json commit-message.config.json tsconfig.json playwright.config.ts tests scripts/generate-commit-msg.cjs scripts/run-lighthouse.cjs site/assets/js .vscode/settings.json",
		"format": "biome format --write package.json biome.json commit-message.config.json tsconfig.json playwright.config.ts tests scripts/generate-commit-msg.cjs scripts/run-lighthouse.cjs site/assets/js .vscode/settings.json",
		"lighthouse": "node scripts/run-lighthouse.cjs",
		"lighthouse:mobile": "node scripts/run-lighthouse.cjs --mobile",
		"lighthouse:desktop": "node scripts/run-lighthouse.cjs --desktop",
		"lighthouse:ci": "node scripts/run-lighthouse.cjs --mobile --desktop --enforce-thresholds",
		"typecheck": "tsc --noEmit",
		"migrate:bmad-memory": "python scripts/migrate_sessions.py",
		"prepare": "husky",
		"test": "jest",
		"test:ci": "npm run lint && npm run typecheck && npm test && npm run test:e2e:ci",
		"test:smoke": "playwright test --config=playwright.config.ts --project=chromium --grep @smoke",
		"test:smoke:mobile": "playwright test --config=playwright.config.ts --project=mobile-chrome --grep @smoke",
		"test:smoke:all": "playwright test --config=playwright.config.ts --grep @smoke",
		"test:e2e": "playwright test --config=playwright.config.ts",
		"test:e2e:ci": "playwright test --config=playwright.config.ts",
		"test:e2e:ui": "playwright test --config=playwright.config.ts --ui",
		"test:e2e:headed": "playwright test --config=playwright.config.ts --headed"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/cli": "^4.2.1",
		"chrome-launcher": "^1.2.1",
		"http-server": "^14.1.1",
		"husky": "^9.1.7",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"lighthouse": "^13.0.3",
		"lint-staged": "^16.4.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3"
	},
	"description": "This is the pre-launch landing page for [genu.im](https://genu.im), a verification and transparency tool that builds consumer trust.",
	"main": "index.js",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/masteroleg/gm.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "commonjs",
	"bugs": {
		"url": "https://github.com/masteroleg/gm/issues"
	},
	"homepage": "https://github.com/masteroleg/gm#readme",
	"jest": {
		"testEnvironment": "jsdom",
		"testMatch": [
			"<rootDir>/tests/**/*.test.js"
		],
		"testPathIgnorePatterns": [
			"<rootDir>/tests/e2e/"
		],
		"setupFiles": [
			"<rootDir>/tests/setup.js"
		]
	},
	"overrides": {
		"serve": {
			"ajv": "^8.18.0"
		},
		"serve-handler": {
			"minimatch": "^3.1.3"
		},
		"glob": {
			"minimatch": "^9.0.6"
		}
	}
}
