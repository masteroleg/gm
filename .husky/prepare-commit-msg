#!/usr/bin/sh

MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Do not override merge commits, squashes, etc.
[ -n "$COMMIT_SOURCE" ] && exit 0

# If the message already has meaningful content (ignoring comments), keep it.
if [ -s "$MSG_FILE" ]; then
    NON_COMMENT=$(grep -v "^#" "$MSG_FILE" | grep -v "^$")
    [ -n "$NON_COMMENT" ] && exit 0
fi

DIFF=$(git diff --cached)
[ -z "$DIFF" ] && exit 0

REPO_ROOT="$(git rev-parse --show-toplevel)"
node "$REPO_ROOT/scripts/generate-commit-msg-opencode.cjs" "$MSG_FILE"

exit 0