#!/bin/sh

MSG_FILE="$1"

# Do not override merge commits, squashes, etc.
COMMIT_SOURCE="$2"
if [ -n "$COMMIT_SOURCE" ]; then
	exit 0
fi

# If the message already has meaningful non-comment content, keep it.
if [ -s "$MSG_FILE" ] && grep -Eq '^[[:space:]]*[^#[:space:]].*' "$MSG_FILE"; then
	exit 0
fi

if command -v node >/dev/null 2>&1; then
	node scripts/generate-commit-msg.cjs "$MSG_FILE"
	exit 0
fi

if command -v node.exe >/dev/null 2>&1; then
	node.exe scripts/generate-commit-msg.cjs "$MSG_FILE"
	exit 0
fi
