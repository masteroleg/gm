{
	"files": {
		"includes": [
			"**",
			"!node_modules",
			"!test-results",
			"!playwright-report",
			"!_bmad-output",
			"!site/assets/css/output.css"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}
