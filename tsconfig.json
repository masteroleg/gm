{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node", "jest"],
		"noEmit": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["playwright.config.ts", "tests/**/*.ts"]
}
